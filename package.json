{
  "name": "behindthewallsapp",
  "version": "1.0.5",
  "main": "index.ts",
  "scripts": {
    "android": "expo run:android",
    "ios": "expo run:ios",
    "ios:dev": "./scripts/dev-build.sh",
    "ios:fast": "expo run:ios --no-build-cache --no-bundler",
    "ios:device": "expo run:ios --device --no-build-cache --no-bundler",
    "ios:superfast": "./scripts/fast-dev.sh",
    "dev": "NODE_ENV=development expo start",
    "web": "expo start --web",
    "start": "expo start",
    "start:dev": "expo start --dev",
    "start:fast": "expo start --no-dev --minify",
    "build:ios": "expo build:ios",
    "build:android": "expo build:android",
    "eject": "expo eject",
    "test": "jest",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "clean": "expo r -c",
    "clean:ios": "cd ios && rm -rf build && cd .. && expo run:ios",
    "clean:all": "rm -rf node_modules ios/build .expo /tmp/metro-cache && npm install && cd ios && pod install",
    "reset": "expo r -c && rm -rf node_modules && npm install && cd ios && pod install"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-navigation/native": "^7.0.0",
    "@react-navigation/native-stack": "^7.0.0",
    "cors": "^2.8.5",
    "expo": "~54.0.0",
    "expo-av": "~16.0.0",
    "expo-constants": "~17.0.3",
    "expo-dev-client": "~6.0.0",
    "expo-file-system": "~18.0.5",
    "expo-font": "~14.0.0",
    "expo-keep-awake": "~13.0.2",
    "expo-status-bar": "~3.0.8",
    "express": "^5.1.0",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-cli": "^2.0.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-webview": "13.15.0",
    "use-sync-external-store": "^1.5.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/react": "~19.1.10",
    "@types/react-native": "~0.73.0",
    "eslint": "^8.57.0",
    "eslint-config-expo": "^7.0.0",
    "jest": "^29.2.1",
    "patch-package": "^8.0.0",
    "typescript": "~5.9.2"
  },
  "private": true
}